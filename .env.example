# Variables de entorno necesarias en Vercel para el contador compartido.
# Se generan automáticamente al conectar una base de datos Upstash Redis
# desde Vercel: Storage → Browse Marketplace → Upstash → Create.
# No es necesario completarlas a mano localmente salvo que quieras probar
# el contador en desarrollo con una base real.

KV_REST_API_URL=
KV_REST_API_TOKEN=
